.container {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.label {
  font-size: 26rpx;
  color: #334155;
  margin: 12rpx 0 8rpx;
}

.input {
  border: 1rpx solid #dbe2ea;
  border-radius: 12rpx;
  padding: 18rpx;
  font-size: 28rpx;
  background: #fff;
}

.btn-primary {
  margin-top: 20rpx;
  background: #2563eb !important;
  color: #fff !important;
  border-radius: 12rpx;
}

.btn-secondary {
  margin-top: 12rpx;
  border-radius: 12rpx;
}

.row {
  display: flex;
  gap: 16rpx;
}

.row > view {
  flex: 1;
}

.tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #1d4ed8;
  background: #e8f0ff;
  margin-right: 10rpx;
  margin-top: 8rpx;
}

.muted {
  color: #64748b;
  font-size: 24rpx;
}
