@import '../../app.wxss';

.home-bg {
  background: linear-gradient(180deg, #f0f6ff 0%, #f7f9fc 240rpx, #f7f9fc 100%);
}

.hero {
  background: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 14rpx 30rpx rgba(37, 99, 235, 0.24);
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.hero-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
}

.hero-user-icon {
  font-size: 32rpx;
}

.hero-user-name {
  font-size: 20rpx;
  color: white;
  margin-top: 4rpx;
}

.stats-row {
  display: flex;
  background: white;
  border-radius: 16rpx;
  padding: 24rpx 0;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.border-l {
  border-left: 1rpx solid #f0f0f0;
}

.stat-val {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.blue-txt { color: #2563eb; }
.red-txt { color: #f5222d; }

.stat-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
}

.hero-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.92);
}

.hero-user {
  margin-top: 10rpx;
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #e0e7ff;
  background: rgba(255, 255, 255, 0.14);
}

.quick-nav {
  margin-top: 16rpx;
  display: flex;
  justify-content: space-around;
  padding: 10rpx 0;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.nav-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.nav-text {
  font-size: 22rpx;
  color: white;
}

.purple-grad {
  background: linear-gradient(135deg, #722ed1 0%, #b37feb 100%);
}

.cyan-grad {
  background: linear-gradient(135deg, #13c2c2 0%, #5cdbd3 100%);
}

.yellow-grad {
  background: linear-gradient(135deg, #faad14 0%, #ffec3d 100%);
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 1000;
}

.modal-content {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: white;
  border-radius: 30rpx 30rpx 0 0;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.3s ease-out;
}

.modal-show {
  transform: translateY(0);
}

.modal-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
}

.modal-close {
  font-size: 44rpx;
  color: #999;
}

.modal-body {
  padding: 20rpx;
}

.footer-logout {
  padding: 40rpx;
}

.btn-ghost {
  margin-top: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.45) !important;
  color: #ffffff !important;
  background: rgba(255, 255, 255, 0.15) !important;
  border-radius: 999rpx;
  padding: 0 28rpx;
  font-size: 26rpx;
  font-weight: 500;
  height: 60rpx;
  line-height: 58rpx;
}

.tool-card {
  border: 1rpx solid #e8eef7;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.06);
}

.tool-head {
  margin-bottom: 10rpx;
}

.tool-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.tool-tip {
  margin-top: 6rpx;
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #4f46e5;
  font-size: 22rpx;
}

.field-grid {
  display: grid;
  gap: 12rpx;
}

.field-grid.two {
  grid-template-columns: 1fr 1fr;
}

.field-grid.three {
  grid-template-columns: 1fr 1fr 1fr;
}

.field-grid.four {
  grid-template-columns: 1fr 1fr 1fr 1fr;
}

.field-grid.compact {
  gap: 10rpx;
}

.field-item {
  min-width: 0;
}

.actions-row {
  margin-top: 14rpx;
}

.small {
  margin-top: 0;
  font-size: 24rpx;
  padding: 8rpx 14rpx;
}

.btn-danger {
  margin-top: 14rpx;
  background: #dc2626 !important;
  color: #fff !important;
  border-radius: 14rpx;
  box-shadow: 0 8rpx 16rpx rgba(220, 38, 38, 0.22);
}

.btn-primary,
.btn-secondary {
  border-radius: 14rpx;
}

.input {
  border-width: 2rpx;
  border-color: #dbe7ff;
  border-radius: 14rpx;
  background: #fbfdff;
}

.input:focus {
  border-color: #2563eb;
}

.input-readonly {
  background: #f1f5f9;
  color: #475569;
}

.picker-like {
  min-height: 44rpx;
  display: flex;
  align-items: center;
  color: #334155;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.result {
  margin-top: 14rpx;
  padding: 14rpx;
  border-radius: 12rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #f1f7ff 100%);
  border: 1rpx solid #dbeafe;
  color: #1e293b;
  font-size: 24rpx;
  line-height: 1.8;
}

.pack-summary {
  margin-top: 12rpx;
  border: 1rpx solid #dbeafe;
  border-radius: 14rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #eef6ff 100%);
  padding: 14rpx;
}

.summary-main {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.summary-label {
  font-size: 24rpx;
  color: #334155;
}

.summary-value {
  font-size: 54rpx;
  line-height: 1;
  font-weight: 800;
  color: #1d4ed8;
}

.summary-unit {
  font-size: 26rpx;
  color: #1e293b;
  font-weight: 600;
}

.summary-formula {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
}

.summary-metrics {
  margin-top: 10rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
}

.metric-item {
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  border-radius: 10rpx;
  padding: 8rpx 10rpx;
}

.metric-k {
  font-size: 20rpx;
  color: #64748b;
}

.metric-v {
  margin-top: 2rpx;
  font-size: 24rpx;
  color: #0f172a;
  font-weight: 600;
}

.canvas-wrap {
  margin-top: 10rpx;
  padding: 4rpx;
  border: 1rpx dashed #cbd5e1;
  border-radius: 12rpx;
  background: #fcfdff;
}

.canvas-title {
  margin-bottom: 6rpx;
  font-size: 22rpx;
  color: #475569;
}

.sketch-canvas {
  width: 640rpx;
  margin-top: 2rpx;
  border: 1rpx solid #dbe4f0;
  border-radius: 10rpx;
  background: #ffffff;
}

.height-canvas {
  width: 640rpx;
  margin-top: 2rpx;
  border: 1rpx solid #dbe4f0;
  border-radius: 10rpx;
  background: #ffffff;
}

.canvas-debug {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #64748b;
}

.card-inner {
  margin-top: 12rpx;
  padding: 14rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  background: #ffffff;
}

.small-title {
  font-size: 28rpx;
}

.mat-list {
  margin-top: 10rpx;
}

.mat-item {
  border: 1rpx solid #e2e8f0;
  border-radius: 10rpx;
  padding: 10rpx;
  margin-bottom: 8rpx;
  background: #f8fafc;
}

.mat-main {
  font-size: 24rpx;
  color: #0f172a;
  font-weight: 600;
}

.mat-remark {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #64748b;
}

.mat-actions {
  margin-top: 8rpx;
  display: flex;
  gap: 10rpx;
}

.tiny {
  margin-top: 0;
  font-size: 22rpx;
  padding: 6rpx 12rpx;
  border-radius: 10rpx;
}

.mat-form {
  margin-top: 8rpx;
  padding-top: 8rpx;
  border-top: 1rpx dashed #cbd5e1;
}

/* 质检入口卡片 */
.qc-entry-card {
  display: flex !important;
  align-items: center;
  padding: 40rpx 36rpx;
  margin-top: -30rpx;
  margin-bottom: 40rpx;
  position: relative;
  z-index: 10;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 15rpx 45rpx rgba(37, 99, 235, 0.1);
  border: 1rpx solid rgba(224, 231, 255, 0.8);
}

.qc-icon-circle {
  width: 140rpx;
  height: 86rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: white;
  border-radius: 43rpx; /* Pill shape */
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  font-weight: 800;
  box-shadow: 0 6rpx 15rpx rgba(37, 99, 235, 0.3);
}

.qc-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #0f172a;
  letter-spacing: 1rpx;
}

.qc-desc {
  font-size: 26rpx;
  color: #64748b;
  margin-top: 10rpx;
}

/* 标题样式优化 */
.section-title {
  display: flex;
  align-items: center;
  margin: 40rpx 0 30rpx 10rpx;
}

.title-line {
  width: 10rpx;
  height: 36rpx;
  background: #2563eb;
  border-radius: 6rpx;
  margin-right: 20rpx;
}

.title-text {
  font-size: 36rpx;
  font-weight: 800;
  color: #1e293b;
}

/* MES 现场操作 列表优化 */
.op-grid-list {
  padding: 0 10rpx;
}

.op-card-item {
  display: flex !important;
  align-items: center;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 25rpx rgba(15, 23, 42, 0.04);
  border: 1rpx solid #f1f5f9;
}

.op-card-item:active {
  background: #f8fafc;
  transform: translateY(2rpx);
}

.op-icon-side {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex !important;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  margin-right: 32rpx;
  flex-shrink: 0;
}

.blue-grad {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #ffffff;
}

.op-info-side {
  flex: 1;
}

.op-name-txt {
  font-size: 32rpx;
  font-weight: 800;
  color: #1e293b;
  margin-bottom: 6rpx;
}

.op-desc-txt {
  font-size: 24rpx;
  color: #64748b;
}
