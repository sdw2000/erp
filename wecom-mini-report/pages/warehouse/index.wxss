.warehouse-bg {
  background-color: #f0f2f5;
  min-height: 100vh;
}

.hero {
  padding: 60rpx 40rpx 100rpx;
  color: white;
  text-align: center;
}

.hero-title {
  font-size: 44rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 10rpx;
}

.main-content {
  margin-top: -60rpx;
  padding: 0 20rpx;
}

.tool-section {
  padding: 20rpx 0;
  margin-bottom: 30rpx;
}

.section-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #4b5563;
  margin-bottom: 20rpx;
}

.scan-btn-large {
  background: #f0f7ff;
  border: 2rpx dashed #2563eb;
  border-radius: 16rpx;
  padding: 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.2s ease;
}

.scan-btn-large:active {
  background: #e0eeff;
  transform: scale(0.98);
}

.scan-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.scan-text {
  font-size: 34rpx;
  font-weight: bold;
  color: #2563eb;
}

.scan-hint {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 10rpx;
}

.tool-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 40rpx 20rpx;
  padding: 20rpx 0;
}

.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.2s;
}

.tool-item:active {
  opacity: 0.7;
  transform: translateY(2rpx);
}

.tool-icon {
  width: 110rpx;
  height: 110rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 16rpx;
  color: white;
}

.tool-name {
  font-size: 26rpx;
  color: #1f2937;
  font-weight: 500;
}

/* 渐变背景 */
.blue-grad {
  background: linear-gradient(135deg, #2563eb 0%, #60a5fa 100%);
}

/* 颜色变态 */
.blue { background: #3b82f6; }
.green { background: #10b981; }
.orange { background: #f59e0b; }
.purple { background: #8b5cf6; }
.teal { background: #14b8a6; }
.indigo { background: #6366f1; }
.red { background: #ef4444; }
.gray { background: #6b7280; }
.cyan { background: #06b6d4; }

/* Modal Styles - Shared in app.wxss usually but can be here too */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 1000;
}

.modal-content {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1001;
  padding-bottom: env(safe-area-inset-bottom);
  transform: translateY(100%);
  transition: all 0.3s ease-out;
}

.modal-show {
  transform: translateY(0);
}

.modal-header {
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid #f3f4f6;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #111827;
}

.modal-close {
  font-size: 48rpx;
  color: #9ca3af;
  padding: 10rpx;
}

.modal-body {
  padding: 40rpx 30rpx;
  max-height: 70vh;
  overflow-y: auto;
}

.info-list {
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 24rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1px solid #f1f5f9;
}

.info-label {
  color: #64748b;
  font-size: 26rpx;
}

.info-value {
  color: #1e293b;
  font-size: 28rpx;
  font-weight: 500;
}

.info-value.highlight {
  color: #2563eb;
  font-weight: bold;
}

.modal-footer {
  padding: 30rpx;
  display: flex;
  gap: 20rpx;
}

.modal-footer button {
  flex: 1;
}

/* Utils */
.shadow-sm {
  box-shadow: 0 1rpx 2rpx 0 rgba(0, 0, 0, 0.05);
}

.tag-STOCK { background: #e0f2fe; color: #0369a1; padding: 4rpx 16rpx; border-radius: 8rpx; font-size: 22rpx; display: inline-block; margin-bottom: 20rpx; }
.tag-WORKSHOP { background: #fef3c7; color: #92400e; padding: 4rpx 16rpx; border-radius: 8rpx; font-size: 22rpx; display: inline-block; margin-bottom: 20rpx; }
.tag-PRODUCTION_TASK { background: #dcfce7; color: #166534; padding: 4rpx 16rpx; border-radius: 8rpx; font-size: 22rpx; display: inline-block; margin-bottom: 20rpx; }
