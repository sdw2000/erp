@import '../../app.wxss';

.mt8 {
  margin-top: 8rpx;
}

.row-middle {
  align-items: center;
  justify-content: space-between;
}

.row-actions {
  align-items: center;
  gap: 8rpx;
}

.row-actions-right {
  justify-content: flex-end;
  margin-top: 8rpx;
}

.item {
  border-top: 1rpx dashed #e2e8f0;
  margin-top: 12rpx;
  padding-top: 12rpx;
}

.small {
  margin-top: 0;
  font-size: 24rpx;
  padding: 8rpx 14rpx;
}

.audit-box {
  margin-top: 10rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid #e2e8f0;
}

.scan-detail {
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed #e2e8f0;
}

.scan-item {
  margin-top: 12rpx;
  padding: 12rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 10rpx;
}

.doc-row {
  margin-top: 14rpx;
  padding: 16rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}

.doc-main {
  flex: 1;
}

.doc-no {
  font-weight: 600;
  font-size: 28rpx;
  margin-bottom: 6rpx;
}

.grid {
  margin-top: 12rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
}

.cell {
  background: #f8fafc;
  border-radius: 10rpx;
  padding: 12rpx;
  font-size: 24rpx;
  color: #334155;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  margin-top: 8rpx;
}

.detail-row .k {
  color: #64748b;
  font-size: 24rpx;
  min-width: 140rpx;
}

.detail-row .v {
  color: #0f172a;
  font-size: 26rpx;
  flex: 1;
  text-align: right;
}

.btn-success {
  margin-top: 0;
  background: #22c55e !important;
  color: #fff !important;
  border-radius: 12rpx;
}

.btn-scan-big {
  min-width: 240rpx;
  height: 108rpx;
  line-height: 108rpx;
  font-size: 36rpx;
  padding: 0 30rpx;
  border-radius: 16rpx;
}

.actions {
  margin-top: 16rpx;
}

.big {
  height: 86rpx;
  line-height: 86rpx;
  font-size: 32rpx;
}

.scan-inbound-btn {
  height: 258rpx !important;
  line-height: 258rpx !important;
  font-size: 42rpx !important;
  font-weight: 700;
  letter-spacing: 2rpx;
  border-radius: 20rpx !important;
  border: none !important;
  color: #ffffff !important;
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%) !important;
  box-shadow: 0 14rpx 28rpx rgba(22, 163, 74, 0.32);
}
