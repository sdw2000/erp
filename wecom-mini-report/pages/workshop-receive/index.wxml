<view class="container">
  <view class="card">
    <view class="section">
      <view class="title">车间批量收货</view>
      <view class="muted">将仓库发出的物料确认进入车间线边仓</view>
    </view>

    <view class="section mt16">
      <view class="label">接收车间/班组</view>
      <view class="row row-middle">
        <picker bindchange="bindSectionChange" value="{{sectionIndex}}" range="{{sections}}" range-key="label" style="flex:1">
          <view class="input select-box">
            {{sections[sectionIndex].label}}
          </view>
        </picker>
        <picker bindchange="bindShiftChange" value="{{shiftIndex}}" range="{{shifts}}" range-key="label" style="flex:1">
          <view class="input select-box">
            {{shifts[shiftIndex].label}}
          </view>
        </picker>
      </view>
    </view>

    <view class="section mt16">
      <view class="label">物料批次扫码</view>
      <view class="row">
        <input class="input" placeholder="请扫码或输入批次号" model:value="{{currentCode}}" confirm-type="send" bindconfirm="addCode" />
        <button class="btn-primary small" bindtap="scanCode">扫码</button>
      </view>
      <view class="hint">可连续扫码添加多个批次</view>
    </view>

    <view class="section mt16" wx:if="{{items.length > 0}}">
      <view class="label">待收货列表 ({{items.length}})</view>
      <view class="list">
        <view class="list-item" wx:for="{{items}}" wx:key="barcode">
          <view class="item-info">
            <view class="item-code">{{item.barcode}}</view>
            <view class="item-material">{{item.materialName}}</view>
            <view class="item-spec">{{item.spec}} | {{item.area}}㎡</view>
          </view>
          <view class="item-remove" bindtap="removeItem" data-index="{{index}}">删除</view>
        </view>
      </view>
    </view>

    <view class="mt16">
      <button class="btn-primary" bindtap="submitReceive" loading="{{loading}}" disabled="{{items.length === 0}}">确认收货</button>
    </view>
  </view>
</view>
