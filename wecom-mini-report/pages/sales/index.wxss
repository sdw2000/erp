.sales-bg {
  background-color: #fcfaf8;
  min-height: 100vh;
}

.hero {
  padding: 60rpx 40rpx 100rpx;
  color: white;
  text-align: center;
}

.hero-title {
  font-size: 44rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 10rpx;
}

.main-content {
  margin-top: -60rpx;
  padding: 0 20rpx;
}

.tool-section {
  padding: 20rpx 0;
  margin-bottom: 30rpx;
}

.section-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #4b5563;
  margin-bottom: 20rpx;
}

.summary-action-btn {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 15rpx rgba(250, 140, 22, 0.1);
  transition: all 0.2s ease;
}

.orange-border {
  border: 1rpx solid #ffd591;
}

.action-icon {
  font-size: 64rpx;
  margin-right: 24rpx;
}

.action-body {
  flex: 1;
}

.action-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fa8c16;
}

.action-desc {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 6rpx;
}

.action-arrow {
  font-size: 32rpx;
  color: #fa8c16;
}

.tool-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 40rpx 20rpx;
  padding: 20rpx 0;
}

.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.2s;
}

.tool-item:active {
  opacity: 0.7;
  transform: translateY(2rpx);
}

.tool-icon {
  width: 110rpx;
  height: 110rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 16rpx;
  color: white;
}

.tool-name {
  font-size: 26rpx;
  color: #1f2937;
  font-weight: 500;
}

/* 渐变背景 */
.orange-grad {
  background: linear-gradient(135deg, #fa8c16 0%, #ffbb96 100%);
}

/* 颜色系统 */
.blue { background: #3b82f6; }
.green { background: #10b981; }
.orange { background: #f97316; }
.purple { background: #8b5cf6; }
.teal { background: #14b8a6; }
.indigo { background: #6366f1; }
.red { background: #ef4444; }
.gray { background: #6b7280; }
.cyan { background: #06b6d4; }
.gold { background: #eab308; }

.shadow-sm {
  box-shadow: 0 4rpx 10rpx 0 rgba(0, 0, 0, 0.05);
}

.card {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
}
