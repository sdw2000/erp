@import '../../app.wxss';

page {
  height: 100%;
  background: #f5f7fb;
  display: block;
  position: relative;
}

.login-bg {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  background: #f5f7fb;
  padding: 60rpx 40rpx 0;
  box-sizing: border-box;
  position: relative;
}

.header-section {
  z-index: 1;
  text-align: center;
  margin-bottom: 40rpx;
  width: 100%;
}

.app-name {
  color: #ffffff;
  font-size: 48rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}

.app-desc {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
  margin-top: 8rpx;
  text-transform: uppercase;
}

.login-bg::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 42vh;
  background: linear-gradient(180deg, #2563eb 0%, #1d4ed8 100%);
  z-index: 0;
  border-bottom-left-radius: 100rpx;
  border-bottom-right-radius: 100rpx;
}

.login-card {
  width: 100%;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(15, 23, 42, 0.12);
  box-sizing: border-box;
  z-index: 1;
  margin-top: 60rpx;
  flex-shrink: 0;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1e293b;
  text-align: center;
  margin-bottom: 8rpx;
  display: block;
}

.subtitle {
  font-size: 24rpx;
  color: #94a3b8;
  text-align: center;
  margin-bottom: 50rpx;
  display: block;
}

.login-form {
  width: 100%;
  display: block;
}

.form-item {
  margin-bottom: 32rpx;
  width: 100%;
}

.form-label {
  font-size: 26rpx;
  color: #475569;
  margin-bottom: 12rpx;
  display: block;
}

.input {
  width: 100% !important;
  height: 88rpx !important;
  background: #f8fafc !important;
  border: 1rpx solid #e2e8f0 !important;
  border-radius: 12rpx !important;
  padding: 0 24rpx !important;
  font-size: 28rpx !important;
  box-sizing: border-box !important;
}

.login-btn {
  width: 100% !important;
  height: 96rpx !important;
  line-height: 96rpx !important;
  background: #2563eb !important;
  color: #ffffff !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  border-radius: 16rpx !important;
  margin-top: 48rpx !important;
  box-shadow: 0 8rpx 20rpx rgba(37, 99, 235, 0.2) !important;
}

.login-footer {
  margin-top: 40rpx;
  text-align: center;
  font-size: 22rpx;
  color: #94a3b8;
}
