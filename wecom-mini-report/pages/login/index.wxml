<view class="container">
  <view class="card">
    <view class="title">企业微信报工</view>
    <view class="muted">请使用 MES 账号登录</view>

    <view class="label">后端地址</view>
    <input class="input" value="{{baseUrl}}" placeholder="http://localhost:8090" bindinput="onBaseUrlInput" />

    <view class="label">账号</view>
    <input class="input" value="{{username}}" placeholder="请输入账号" bindinput="onUsernameInput" />

    <view class="label">密码</view>
    <input class="input" password value="{{password}}" placeholder="请输入密码" bindinput="onPasswordInput" />

    <button class="btn-primary" loading="{{loading}}" bindtap="onLogin">登录</button>
  </view>
</view>
