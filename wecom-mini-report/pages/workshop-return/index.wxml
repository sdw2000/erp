<view class="container">
  <view class="card">
    <view class="title">车间批量退料到仓库</view>
    <view class="muted">请先选择目标仓库，然后连续扫码添加物料，最后统一提交。</view>

    <view class="section mt16">
      <view class="label">1. 选择退回的目标仓库</view>
      <picker mode="selector" range="{{warehouseOptions}}" value="{{warehouseIndex}}" bindchange="onWarehouseChange">
        <view class="input select-box">{{warehouseOptions[warehouseIndex]}}</view>
      </picker>
    </view>

    <view class="section mt16">
      <view class="label">2. 扫码物料标签 (支持连续扫码)</view>
      <view class="row row-middle">
        <input class="input" value="{{currentCode}}" placeholder="扫码或输入批次号" bindinput="onCodeInput" confirm-type="add" bindconfirm="addCodeByInput" />
        <button class="btn-primary small" bindtap="onScanCode">扫码</button>
      </view>
      <view class="hint">目前已添加 {{scannedItems.length}} 件物料</view>
    </view>

    <view class="section mt16" wx:if="{{scannedItems.length > 0}}">
      <view class="label">3. 确认物料清单</view>
      <view class="list">
        <block wx:for="{{scannedItems}}" wx:key="qrCode">
          <view class="list-item">
            <view class="item-info">
              <view class="item-code">{{item.qrCode}}</view>
              <view class="item-material">{{item.materialCode || '正在检测...'}}</view>
              <view class="item-spec" wx:if="{{item.spec}}">{{item.spec}}</view>
            </view>
            <view class="item-remove" bindtap="removeItem" data-index="{{index}}">删除</view>
          </view>
        </block>
      </view>
    </view>

    <view class="section mt16">
      <view class="label">备注 (可选)</view>
      <input class="input" value="{{remark}}" placeholder="例如：生产剩余、订单变更" bindinput="onRemarkInput" />
    </view>

    <view class="row mt16">
      <button class="btn-danger" bindtap="clearAll">清空列表</button>
      <button class="btn-primary" loading="{{submitting}}" bindtap="submitReturn">提交退料 ({{scannedItems.length}})</button>
    </view>
  </view>
</view>
