@import '../../app.wxss';

.row-middle {
  align-items: center;
  justify-content: space-between;
}

.mt8 {
  margin-top: 8rpx;
}

.small {
  margin-top: 0;
  font-size: 24rpx;
  padding: 8rpx 14rpx;
}

.row-actions {
  gap: 8rpx;
}

.row-actions .small {
  min-width: 180rpx;
}

.schedule-item {
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 14rpx;
  margin: 10rpx 0;
}

.schedule-item-active {
  border-color: #2563eb;
  background: #eff6ff;
}

.issue-card {
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 16rpx;
  margin: 16rpx 0;
}

.issue-history {
  border-top: 1rpx dashed #e2e8f0;
  padding-top: 12rpx;
  margin-top: 12rpx;
}

.mt16 {
  margin-top: 16rpx;
}

.highlight {
  border-color: #2563eb !important;
  background-color: #f0f7ff !important;
  font-weight: bold;
}

.disabled {
  background-color: #f7fafc;
  color: #718096;
}

.btn-danger {
  margin-top: 12rpx;
  background: #ef4444 !important;
  color: #fff !important;
  border-radius: 10rpx;
}
