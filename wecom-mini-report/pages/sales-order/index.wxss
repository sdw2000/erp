@import '../../app.wxss';

.row-middle {
  align-items: flex-end;
}

.small {
  margin-top: 0;
  margin-left: 12rpx;
  font-size: 24rpx;
  padding: 10rpx 16rpx;
  white-space: nowrap;
}

.picker-input {
  margin-top: 8rpx;
}

.item-card {
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-top: 14rpx;
  background: #f8fafc;
}

.remark-tags {
  margin-top: 10rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
}

.btn-danger {
  margin-top: 12rpx;
  background: #ef4444 !important;
  color: #fff !important;
  border-radius: 10rpx;
}

.mini {
  margin-top: 0;
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  line-height: 1.2;
}

.match-reason {
  margin-top: 6rpx;
  color: #dc2626;
  font-size: 22rpx;
}
