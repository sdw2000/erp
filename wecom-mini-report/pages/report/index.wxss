.report-bg {
  background-color: #f8fafc;
  min-height: 100vh;
}

.hero-mini {
  padding: 40rpx 30rpx 80rpx;
  color: white;
}
.hero-title {
  font-size: 40rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}
.hero-sub {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 10rpx;
}

.blue-grad {
  background: linear-gradient(135deg, #2563eb 0%, #60a5fa 100%);
}

.main-content {
  margin-top: -40rpx;
  padding: 0 20rpx;
}

.card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.card-header-modern {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.title-main {
  font-size: 32rpx;
  font-weight: bold;
  color: #1e293b;
}

.title-sub {
  font-size: 22rpx;
  color: #94a3b8;
}

.refresh-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f1f5f9;
  border-radius: 50%;
}
.refresh-btn.loading {
  animation: rotate 1s linear infinite;
}
@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.section-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #4b5563;
  margin-bottom: 12rpx;
}

/* Picker & Input Modern */
.picker-modern {
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 12rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.picker-modern.mini {
  padding: 16rpx 20rpx;
}
.picker-val {
  font-size: 28rpx;
  color: #1e293b;
}
.arrow-down {
  font-size: 20rpx;
  color: #64748b;
}

.filter-row {
  display: flex;
  gap: 20rpx;
}
.filter-item {
  flex: 1;
}
.flex2 { flex: 2; }

/* Search Bar Modern */
.search-bar-modern {
  display: flex;
  background: #f8fafc;
  border-radius: 12rpx;
  padding: 0 0 0 24rpx;
  align-items: center;
  border: 1px solid #e2e8f0;
}
.search-bar-modern.mini {
  height: 80rpx;
}
.input-modern {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
}

.scan-icon-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

/* Schedule List Cards */
.schedule-card-modern {
  background: #ffffff;
  border: 1px solid #f1f5f9;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  position: relative;
  transition: all 0.2s;
}
.schedule-card-modern.is-active {
  border-color: #2563eb;
  background: #f0f7ff;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.1);
}

.s-card-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}
.s-id-tag {
  font-size: 20rpx;
  color: #2563eb;
  background: #eff6ff;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  font-weight: 600;
}
.s-time-tag {
  font-size: 20rpx;
  color: #059669;
  font-weight: 600;
}
.s-line-tag {
  font-size: 20rpx;
  color: #64748b;
}
.s-order-no {
  font-size: 28rpx;
  font-weight: bold;
  color: #1e293b;
}
.s-material {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 4rpx;
}
.s-spec {
  font-size: 22rpx;
  color: #2563eb;
  background: #f0f7ff;
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-top: 8rpx;
  font-family: monospace;
}
.s-stats {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #94a3b8;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.active-dot {
  width: 12rpx;
  height: 12rpx;
  background: #2563eb;
  border-radius: 50%;
  box-shadow: 0 0 8rpx rgba(37, 99, 235, 0.5);
}

/* Form Details */
.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

/* Modal UI */
.modal-root {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(4px);
}

.modal-container {
  position: relative;
  width: 90%;
  max-width: 640rpx;
  z-index: 1001;
  animation: modalScale 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes modalScale {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

.no-margin {
  margin-bottom: 0 !important;
}

.close-modal-btn {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #94a3b8;
  background: #f1f5f9;
  border-radius: 50%;
  margin-left: 20rpx;
}

.input-wrapper-modern {
  display: flex;
  align-items: center;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 12rpx;
  padding: 0 20rpx;
}

.unit-tag {
  font-size: 24rpx;
  color: #64748b;
  margin-left: 10rpx;
}

.textarea-modern {
  width: 100%;
  height: 160rpx;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.advance-options {
  border-top: 1px solid #f1f5f9;
  padding-top: 20rpx;
}

/* 涂布详情组件样式 */
.roll-input-card {
  background: #f1f5f9;
  border-radius: 12rpx;
  padding: 20rpx;
