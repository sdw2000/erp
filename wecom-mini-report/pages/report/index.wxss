@import '../../app.wxss';

.row-middle {
	align-items: center;
	justify-content: space-between;
}

.small {
	margin-top: 0;
	font-size: 24rpx;
	padding: 8rpx 14rpx;
}

.schedule-item {
	border: 1rpx solid #e2e8f0;
	border-radius: 12rpx;
	padding: 14rpx;
	margin: 10rpx 0;
}

.schedule-item-active {
	border-color: #2563eb;
	background: #eff6ff;
}
